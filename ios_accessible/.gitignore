# Xcode
build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.xcscmblueprint
*.xcuserstate

# Swift Package Manager
.swiftpm/
Packages/
Package.pins
Package.resolved
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm

# Firebase — this is project/environment-specific config (API keys, app IDs),
# not something that should be duplicated in version control. Each developer
# or build environment should drop their own copy in place locally instead.
GoogleService-Info.plist
GoogleService-Info-*.plist
google-services.json

# APNs auth key, if push notifications (e.g. via Firebase Cloud Messaging)
# get added later — grants push-sending privileges for the whole account.
*.p8

# Firebase Local Emulator Suite, if it gets used later
.firebase/
firebase-debug.log
firebase-debug.*.log
ui-debug.log

.DS_Store
