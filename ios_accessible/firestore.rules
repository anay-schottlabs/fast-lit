rules_version = '2';

// Firestore Security Rules for the fast-lit-ios Firebase project. Not
// deployed automatically — apply this via the Firebase Console
// (Firestore Database > Rules) or `firebase deploy --only firestore:rules`
// with the Firebase CLI logged into this project.
service cloud.firestore {
  match /databases/{database}/documents {

    // Registry of taken library usernames (see AuthService.isUsernameTaken
    // / registerUsername in the iOS app). Each doc's ID is the username
    // itself; its mere existence means that username is taken. The real,
    // authoritative uniqueness guarantee is still the Firebase Auth
    // account created alongside it — this collection only exists so a
    // sign-up in progress can check "is this taken?" before an Auth
    // account exists to check against, since Auth's own equivalent check
    // (fetchSignInMethods) is blocked by email enumeration protection.
    match /libraryUsernames/{username} {
      // Anyone can check whether a username is taken — the stored fields
      // (uid, createdAt) aren't sensitive, and the whole point of this
      // collection is that its existence is checkable pre-sign-up, before
      // the checker has an account of their own.
      allow get: if true;

      // Only a signed-in user can register a username, and only as their
      // own account (uid must match the caller) — stops someone else
      // squatting on a name or overwriting an existing registration.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['uid', 'createdAt']);

      // Registrations are permanent from the client's side — no editing
      // or freeing up a username once it's taken.
      allow update, delete: if false;

      // No reason for a client to need the full list of taken usernames.
      allow list: if false;
    }

    // A library account's own profile (username + join code), keyed by
    // uid rather than username — this is "my own data", read back by the
    // signed-in owner via their own uid, not looked up by name the way
    // libraryUsernames above is. See AuthService.createLibraryProfile /
    // fetchLibraryProfile and LibraryView, which displays the join code.
    match /libraries/{uid} {
      // Only the account owner can read their own profile/join code.
      allow get: if request.auth != null && request.auth.uid == uid;

      // Only the account owner can create their own profile, and only
      // with these exact fields.
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys().hasOnly(['username', 'joinCode', 'createdAt']);

      // No editing or deleting from the client — there's no "regenerate
      // join code" feature yet.
      allow update, delete: if false;

      // No reason for a client to need every library's profile at once.
      allow list: if false;
    }

    // A second registry alongside libraryUsernames above, keyed by join
    // code instead of username. Readers have no account and never sign
    // in — this is how ReaderAccountView resolves a typed-in code straight
    // to a library's name via a single get-by-ID, no auth or query needed.
    match /libraryJoinCodes/{joinCode} {
      // Anyone can look up a code — that's the entire point, since readers
      // are never signed in when they do this.
      allow get: if true;

      // Only a signed-in library account can register its own join code,
      // and only as itself (uid must match the caller) — stops someone
      // else claiming or overwriting another library's code.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['uid', 'libraryName', 'createdAt']);

      // Permanent from the client's side — no editing or freeing up a join
      // code once it's registered.
      allow update, delete: if false;

      // No reason for a client to need the full list of join codes.
      allow list: if false;
    }

    // The shared reading catalog every library draws from. Reading
    // material itself isn't sensitive or account-specific — both readers
    // (who have no account at all) and library owners (building the
    // "which parts are enabled" toggle list) need to list and read the
    // whole thing.
    match /catalog/{contentId} {
      allow get: if true;
      allow list: if true;

      // Only ever written by the one-off admin import script
      // (scripts/import-catalog.js), which uses the Admin SDK and so
      // bypasses these rules entirely — nothing in the client app creates,
      // edits, or removes catalog items.
      allow create, update, delete: if false;
    }

    // Which catalog items a library has enabled for its own readers. Kept
    // separate from libraries/{uid} above (rather than a field on it)
    // since this needs to be publicly readable: readers have no account
    // and never sign in, so they need to fetch this straight after
    // joining a library by its code, without auth.
    match /libraryCatalogSelections/{uid} {
      allow get: if true;

      // Only the library account itself can set which items are enabled,
      // and only for its own uid.
      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && request.resource.data.keys().hasOnly(['enabledContentIds', 'updatedAt']);

      allow delete: if false;

      // No reason for a client to need every library's selections at once.
      allow list: if false;
    }
  }
}
